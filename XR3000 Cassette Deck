function learnDuration(){
  if(!player||!player.getVideoData)return;
  const d=player.getDuration&&player.getDuration();
  const vd=player.getVideoData()||{};
  if(d&&d>0&&vd.video_id&&durs[vd.video_id]!==Math.round(d)){
    durs[vd.video_id]=Math.round(d);saveDurs();
  }
