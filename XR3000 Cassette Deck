/* Tape formulation: each type has a real noise floor and bias requirement.
   Ferric hisses most and needs least bias; metal is quietest and needs most. */
const TAPES={
  I:{name:"FERRIC",   hiss:1.00, bias:0, eq:"120\u00B5s"},
  II:{name:"CHROME",  hiss:0.62, bias:2, eq:"70\u00B5s"},
  IV:{name:"METAL",   hiss:0.40, bias:4, eq:"70\u00B5s"}
};
let tapeType="IV";
function swOn(n){const t=document.querySelector('[data-sw="'+n+'"]');return t&&t.classList.contains("on");}
/* Bias mis-set doesn't just change level: under-bias makes the tape hissy and
   thin, over-bias dulls the top. The BIAS FINE knob is scored against what the
   loaded formulation actually wants, so a metal tape at bias 0 sounds wrong. */
function biasError(){
  const set=parseInt($("biasFine").value,10)||0;
  return set-TAPES[tapeType].bias;   /* negative = under-biased */
}
function hissTarget(){
  if(!presetOn()||!(state==="play"||state==="rec"))return 0;
  let g=.006*TAPES[tapeType].hiss;
  if(swOn("dolbyB"))g*=.35;
  if(swOn("dolbyC"))g*=.12;
  const err=biasError();
  if(err<0)g*=1+Math.abs(err)*.22;   /* under-bias: noisier */
  if(state==="rec")g*=1.5;           /* record head is live: more noise through */
  return g;
}
/* Dolby rolls the hiss band down; MPX notches the 19kHz pilot region.
   Bias tilts where the hiss sits: over-biased tape is duller, so the hiss
   moves down with it. */
function updateTapeAudio(){
  if(!AC)return;
  const t=AC.currentTime;
  hissGain.gain.setTargetAtTime(hissTarget(),t,.2);
  if(hissHP){
    const err=biasError();
    let f=2500;
    if(swOn("dolbyB"))f=4200;
    if(swOn("dolbyC"))f=6000;
    f*=Math.pow(1.06,-err);           /* over-bias dulls, under-bias brightens */
    hissHP.frequency.setTargetAtTime(Math.max(1200,Math.min(9000,f)),t,.25);
  }
  if(mpxNotch)mpxNotch.gain.setTargetAtTime(swOn("mpx")?-24:0,t,.2);
  const motor=(presetOn()&&(state==="play"||state==="rec"))?.006:
              (presetOn()&&(state==="ff"||state==="rw"))?.015:0;
  motorGain.gain.setTargetAtTime(motor,t,.12);
}
