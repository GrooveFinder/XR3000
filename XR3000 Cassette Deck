  if(mm)mm.textContent="TYPE "+tt+" \u00B7 "+TAPES[tt].eq+" EQ";
  const err=biasError();
  setStatus("TAPE TYPE "+tt+" \u00B7 "+TAPES[tt].name+" \u00B7 "+TAPES[tt].eq+" EQ"+
