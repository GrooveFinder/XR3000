function estWith(ids){
  const known=ids.map(id=>durs[id]).filter(Boolean);
  const avg=known.length?known.reduce((a,b)=>a+b,0)/known.length:240;
  return ids.map(id=>durs[id]||avg);
}
function timeProgress(t,d){
  const pl=player.getPlaylist&&player.getPlaylist();
  if(!pl||!pl.length)return d?t/d:0;
  const idx=player.getPlaylistIndex(), half=Math.ceil(pl.length/2);
  const inB=idx>=half;
  const sideIds=inB?pl.slice(half):pl.slice(0,half);
  const sideIdx=inB?(idx-half):idx;
  const lens=estWith(sideIds);
  const total=lens.reduce((a,b)=>a+b,0);
  if(!total)return 0;
  const before=lens.slice(0,sideIdx).reduce((a,b)=>a+b,0);
  return (before+Math.min(t,lens[sideIdx]||t))/total;
