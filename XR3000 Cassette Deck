      inset -6px 0 12px -6px rgba(0,0,0,.5),
      inset 0 0 30px rgba(0,0,0,.30);
    transition:transform .8s cubic-bezier(.6,-0.3,.4,1.3), box-shadow .6s;
  }
  .cassette::before{ /* chrome shell wall */
    content:"";position:absolute;inset:-9px;border-radius:9px;z-index:-1;
    background:linear-gradient(150deg,#fafbfd 0%,#c9ced6 16%,#82878f 38%,#e8ecf1 56%,#9aa0a9 76%,#f2f4f7 100%);
    box-shadow:0 2px 6px rgba(0,0,0,.6), inset 0 1px 1px rgba(255,255,255,.85), inset 0 -2px 4px rgba(20,25,35,.6);
  }
  .cassette.flipping{transform:rotateY(90deg) scale(.96);}
  /* moulded inner window: the recessed area the reels sit in */
  .cassette .moulding{position:absolute;left:5%;right:5%;top:9%;bottom:26%;z-index:1;
    border-radius:5px;pointer-events:none;
    border:1px solid rgba(225,235,248,.18);
    box-shadow:
      inset 0 4px 10px rgba(0,0,0,.5),
      inset 0 -2px 0 rgba(255,255,255,.18),
      inset 3px 0 7px -3px rgba(0,0,0,.45),
      inset -3px 0 7px -3px rgba(0,0,0,.45),
      0 1px 0 rgba(255,255,255,.14);}
  /* lower deck: the ribbed plastic strip under the reels */
  .cassette .rib-deck{position:absolute;left:5%;right:5%;bottom:6%;height:17%;z-index:1;
    border-radius:3px;pointer-events:none;
    background:
      repeating-linear-gradient(90deg,rgba(255,255,255,.10) 0 1.5px,transparent 1.5px 6px),
      linear-gradient(180deg,rgba(235,242,252,.13),rgba(15,17,22,.30));
    border-top:1px solid rgba(230,240,252,.20);
    box-shadow:inset 0 1px 0 rgba(255,255,255,.25), inset 0 -2px 4px rgba(0,0,0,.4);}
  .cassette .screw{position:absolute;width:12px;height:12px;border-radius:50%;z-index:5;
    background:
      radial-gradient(circle at 50% 50%, #0a0b0d 0 26%, transparent 27%),
      linear-gradient(90deg,transparent 44%,#0a0b0d 44% 56%,transparent 56%),
      radial-gradient(circle at 38% 32%, #eef1f5 0%, #b9bfc7 30%, #767c85 62%, #43474e 100%);
    box-shadow:
      inset 0 2px 3px rgba(0,0,0,.75),
      inset 0 -1px 1px rgba(255,255,255,.5),
      0 1px 0 rgba(255,255,255,.35);
    border:1px solid rgba(20,24,30,.75);}
  .screw.s1{left:1.8%;top:5%}.screw.s2{right:1.8%;top:5%}
  .screw.s3{left:1.8%;bottom:7%}.screw.s4{right:1.8%;bottom:7%}.screw.s5{left:calc(50% - 6px);bottom:7%}
  /* clear-shell reels visible edge to edge */
  .reelSvg{position:absolute;inset:0;width:100%;height:100%;z-index:1;
    filter:drop-shadow(0 4px 6px rgba(0,0,0,.55));}
  @keyframes spin{to{transform:rotate(360deg)}}
  .reel-rot{transform-origin:center;transform-box:fill-box;}
  .playing .reel-rot{animation:spin var(--spin,2.4s) linear infinite;animation-direction:reverse;}
  .playing.ff .reel-rot{animation-duration:var(--spin,.5s);}
  .playing.rw .reel-rot{animation-duration:var(--spin,.5s);animation-direction:normal;}
  .sideB.playing .reel-rot{animation-direction:normal;}
  .sideB.playing.rw .reel-rot{animation-direction:reverse;}
  /* slim label band across the top */
  .band{position:absolute;left:6%;right:6%;top:6%;height:16%;z-index:2;
    background:linear-gradient(180deg,#f4f1e8,#ddd7c6);border-radius:4px;
    display:flex;align-items:center;justify-content:space-between;padding:0 4%;
    box-shadow:0 2px 6px rgba(0,0,0,.5), inset 0 -1px 2px rgba(0,0,0,.25);}
  .tdk-logo{color:#d0021b;font-weight:900;font-size:clamp(12px,3vw,17px);font-family:Arial,sans-serif;letter-spacing:.04em;}
  .max-badge{font-weight:900;font-style:italic;font-size:clamp(11px,2.6vw,15px);color:#15130f;}
  .max-badge b{color:#d0021b;}
  .band .tiny{font-size:clamp(6px,1.3vw,7.5px);letter-spacing:.14em;color:#5c564a;}
  .song-band{position:absolute;left:6%;right:6%;bottom:19%;z-index:2;text-align:center;
    font-family:"Courier New",monospace;font-size:clamp(7px,1.8vw,10.5px);color:#cfc9bb;
    text-shadow:0 1px 2px #000;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .side-mark{position:absolute;left:4%;bottom:5%;z-index:2;font-weight:900;
    color:var(--champagne);font-size:clamp(11px,2.8vw,15px);text-shadow:0 1px 2px #000;}
  .metal-mark{position:absolute;right:4%;bottom:6%;z-index:2;font-size:clamp(6px,1.3vw,7.5px);
    letter-spacing:.12em;color:var(--champagne-mute);}

  /* ================= Right column ================= */
  .right-col{flex:1 1 400px;min-width:310px;display:flex;flex-direction:column;gap:12px;}
  .glass{background:
      radial-gradient(ellipse at 50% 150%,var(--glass-deep) 0%,var(--glass-mid) 55%,#04070e 100%);
    border:1px solid color-mix(in srgb, var(--fl-blue) 45%, #15161a);border-radius:4px;
    clip-path:polygon(10px 0,100% 0,100% calc(100% - 10px),calc(100% - 10px) 100%,0 100%,0 10px);
    box-shadow:inset 0 0 26px var(--glass-glow), inset 0 2px 8px rgba(0,0,0,.85),
      inset 0 1px 0 rgba(255,255,255,.25), inset 0 0 0 1px rgba(255,255,255,.06),
      0 0 14px color-mix(in srgb, var(--glow-blue) 45%, transparent);position:relative;overflow:hidden;}
  .glass::after{content:"";position:absolute;left:0;right:0;top:0;height:2px;pointer-events:none;
    background:var(--prism);opacity:.55;}
  .glass::before{content:"";position:absolute;inset:0;pointer-events:none;
    background:
      repeating-linear-gradient(180deg,rgba(0,0,0,.16) 0 1px,transparent 1px 3px),
      linear-gradient(105deg,rgba(190,225,255,.08) 0%,transparent 35%);}
  .fl-panel{padding:12px 16px 8px;}
  .scale{display:flex;justify-content:space-between;font-size:9px;letter-spacing:.08em;padding:0 2px 5px 34px;}
  .scale .red{color:#ff8a7e;}
  .bar-row{display:flex;align-items:center;gap:9px;margin-bottom:7px;}
  .bar-row .ch{width:25px;font-size:9.5px;letter-spacing:.2em;}
  .bar{flex:1;display:flex;gap:2px;height:13px;}
  .seg{flex:1;border-radius:1px;background:#0a0b0d;border:1px solid rgba(255,255,255,.04);box-shadow:inset 0 1px 1px rgba(0,0,0,.7);}
  .seg.on{background:color-mix(in srgb, var(--fl-blue) 80%, #fff);
    box-shadow:0 0 4px var(--glow-blue), 0 0 9px color-mix(in srgb, var(--glow-blue) 55%, transparent);
    border-color:transparent;}
  .seg.on.mid{background:#ffd98a;box-shadow:0 0 4px rgba(255,194,87,.9), 0 0 9px rgba(255,194,87,.5);}
  .seg.on.hot{background:#ff8a7e;box-shadow:0 0 5px rgba(255,90,78,.9), 0 0 11px rgba(255,90,78,.5);}
  .seg.peak{background:var(--fl-amber)!important;box-shadow:0 0 8px rgba(255,194,87,.8)!important;}
  .info-panel{padding:12px 16px;font-family:"Share Tech Mono",monospace;}
  .info-row{display:flex;gap:10px;align-items:baseline;margin:3.5px 0;min-height:15px;}
  .info-row .k{font-size:9px;letter-spacing:.24em;width:66px;flex:none;font-family:Helvetica,Arial,sans-serif;}
  .info-row .v{font-size:12.5px;color:color-mix(in srgb, var(--fl-blue) 80%, #fff);
    text-shadow:0 0 2px var(--glow-blue), 0 0 7px color-mix(in srgb, var(--glow-blue) 55%, transparent);
    white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1;}
  .info-row .v.grn{color:color-mix(in srgb, var(--fl-green) 80%, #fff);
    text-shadow:0 0 2px var(--glow-green), 0 0 7px color-mix(in srgb, var(--glow-green) 55%, transparent);}
  /* A real counter's digits are all the same width — they're segments in fixed
     cells. Orbitron's digits are proportional by default, so '1' is narrower
     than '0' and the counter's width changed on every tick, shunting the
     duration and the arrows sideways. tabular-nums locks the cells; fixed
     tracks stop the row redistributing as the contents change. */
  .info-foot{display:grid;
    grid-template-columns:auto auto 1fr auto;
    align-items:center;gap:14px;margin-top:8px;
    border-top:1px solid var(--hairline);padding-top:8px;}
  .digits{font-family:Orbitron,sans-serif;font-weight:700;font-size:18px;letter-spacing:.12em;
    font-variant-numeric:tabular-nums;font-feature-settings:"tnum" 1;
    white-space:nowrap;
    color:color-mix(in srgb, var(--fl-blue) 75%, #fff);
    text-shadow:0 0 2px var(--glow-blue), 0 0 7px color-mix(in srgb, var(--glow-blue) 65%, transparent);}
  /* Belt and braces: even if the webfont ships no tabular figures, a reserved
     width means the counter's box can never resize as the digits change. */
  #counter{min-width:6.4ch;display:inline-block;}
  #duration{min-width:7.2ch;display:inline-block;}
  .dir{display:flex;gap:9px;font-size:13px;justify-self:center;}
  .dir span{color:var(--scale-dim);transition:.2s;}
  .dir span.lit{color:color-mix(in srgb, var(--fl-green) 70%, #fff);
    text-shadow:0 0 2px var(--glow-green), 0 0 8px color-mix(in srgb, var(--glow-green) 60%, transparent);}
  .naac{font-size:9px;letter-spacing:.22em;font-family:Helvetica,Arial,sans-serif;}
  .naac.lit{color:var(--fl-amber);text-shadow:0 0 9px rgba(255,194,87,.6);animation:naacPulse 1.6s ease-in-out 3;}
  @keyframes naacPulse{50%{opacity:.35}}
    50%{transform:translateX(-.3px)}75%{transform:translateX(.2px)}100%{transform:translateX(0)}}
  .monitor{border:1px solid color-mix(in srgb, var(--fl-blue) 30%, #15161a);border-radius:4px;
    clip-path:polygon(10px 0,100% 0,100% calc(100% - 10px),calc(100% - 10px) 100%,0 100%,0 10px);
    overflow:hidden;background:#000;position:relative;
    box-shadow:0 0 8px color-mix(in srgb, var(--glow-blue) 30%, transparent);}
  .monitor .cap{position:absolute;top:5px;left:9px;z-index:2;font-size:9px;letter-spacing:.28em;color:var(--scale-dim);
    background:rgba(0,0,0,.55);padding:2px 7px;border-radius:2px;pointer-events:none;}
  .monitor .frame{aspect-ratio:16/9;width:100%;}
  .monitor iframe{width:100%!important;height:100%!important;display:block;}
  .monitor.min .frame{aspect-ratio:auto;height:42px;}
  /* Expanded, the toggle sits over live video: a faint scrim keeps it legible
     against bright footage without turning it back into a button. */
  .monitor:not(.min) .mon-toggle{background:rgba(0,0,0,.45);opacity:.55;}
  .monitor:not(.min) .mon-toggle:hover{background:rgba(0,0,0,.7);opacity:1;}
  /* Video toggle: a quiet corner marking on the monitor glass, not a button box. */
  .mon-toggle{position:absolute;top:5px;right:8px;z-index:2;font-size:7.5px;
    background:none;border:none;padding:2px 3px;border-radius:2px;
    color:var(--scale-dim);opacity:.4;cursor:pointer;letter-spacing:.22em;
    font-family:Orbitron,sans-serif;font-weight:700;text-shadow:none;
    transition:opacity .25s, color .25s, text-shadow .25s;}
  .mon-toggle:hover{opacity:1;color:var(--fl-blue);
    text-shadow:0 0 6px color-mix(in srgb, var(--glow-blue) 55%, transparent);}
  .mon-toggle:focus-visible{opacity:1;color:var(--fl-blue);outline:1px solid var(--fl-blue);outline-offset:2px;}

  /* ================= Controls ================= */
  .controls{display:flex;gap:18px;flex-wrap:wrap;align-items:flex-end;margin-top:18px;
    padding-top:14px;border-top:1px solid var(--gold-line);}
  .switch{display:flex;flex-direction:column;align-items:center;gap:6px;}
  .switch .cap{font-size:8.5px;letter-spacing:.16em;text-align:center;line-height:1.5;font-family:Orbitron,sans-serif;}
  .toggle{width:46px;height:21px;border-radius:3px;background:linear-gradient(180deg,#0b0a08,#191712);
    border:1px solid #3d382e;cursor:pointer;position:relative;
    box-shadow:inset 0 2px 5px rgba(0,0,0,.85), 0 1px 0 rgba(255,244,214,.06);}
  .toggle .knob{position:absolute;top:2px;left:2px;width:20px;height:15px;border-radius:2px;
    background:linear-gradient(180deg,#ffffff 0%,#dfe5ee 22%,#9aa2ad 52%,#f2f6fb 62%,#878e99 100%);
    transition:left .1s;box-shadow:0 1px 3px rgba(0,0,0,.7), inset 0 1px 0 rgba(255,255,255,.9);}
  .toggle .knob::after{content:"";position:absolute;left:0;right:0;top:0;height:1.5px;
    background:var(--prism);opacity:.7;}
  .toggle.on .knob{left:22px;}
  .lamp{width:6px;height:6px;border-radius:50%;background:#1c2f1c;}
  .toggle.on + .lamp{background:color-mix(in srgb, var(--fl-green) 60%, #fff);
    box-shadow:0 0 8px var(--glow-green), 0 0 18px var(--glow-green), 0 0 30px color-mix(in srgb, var(--glow-green) 60%, transparent);}
  .disp-select{gap:8px;}
  .disp-dots{display:flex;gap:7px;align-items:center;height:21px;padding:0 6px;border-radius:3px;
    background:linear-gradient(180deg,#0b0a08,#191712);border:1px solid #3d382e;
    box-shadow:inset 0 2px 5px rgba(0,0,0,.85);}
  .dot{width:11px;height:11px;border-radius:50%;border:1px solid rgba(0,0,0,.6);cursor:pointer;
    background:radial-gradient(circle at 35% 30%, var(--c), color-mix(in srgb, var(--c) 35%, #000));
    opacity:.4;transition:.15s;}
  .dot:hover{opacity:.75;}
  .dot.active{opacity:1;box-shadow:0 0 9px var(--c), inset 0 1px 1px rgba(255,255,255,.5);}
  .slider-group{display:flex;flex-direction:column;align-items:center;gap:5px;}
  /* Sliders: a lit track with a glowing thumb, not a flat accent swatch. */
  .slider-group input{width:120px;accent-color:var(--fl-blue);
    -webkit-appearance:none;appearance:none;height:4px;border-radius:3px;
    background:linear-gradient(90deg,
      color-mix(in srgb, var(--fl-blue) 85%, #fff),
      var(--fl-blue));
    box-shadow:0 0 10px color-mix(in srgb, var(--glow-blue) 65%, transparent),
      inset 0 1px 2px rgba(0,0,0,.6);
    outline:none;cursor:pointer;}
  .slider-group input::-webkit-slider-thumb{-webkit-appearance:none;appearance:none;
    width:14px;height:14px;border-radius:50%;cursor:pointer;
    background:radial-gradient(circle at 38% 32%, #fff 0%,
      color-mix(in srgb, var(--fl-blue) 55%, #fff) 40%, var(--fl-blue) 100%);
    border:1px solid color-mix(in srgb, var(--fl-blue) 90%, #fff);
    box-shadow:0 0 8px var(--glow-blue), 0 0 18px color-mix(in srgb, var(--glow-blue) 70%, transparent);}
  .slider-group input::-moz-range-thumb{
    width:13px;height:13px;border-radius:50%;cursor:pointer;
    background:radial-gradient(circle at 38% 32%, #fff 0%,
      color-mix(in srgb, var(--fl-blue) 55%, #fff) 40%, var(--fl-blue) 100%);
    border:1px solid color-mix(in srgb, var(--fl-blue) 90%, #fff);
    box-shadow:0 0 8px var(--glow-blue), 0 0 18px color-mix(in srgb, var(--glow-blue) 70%, transparent);}
  .slider-group input::-moz-range-track{height:4px;border-radius:3px;background:var(--fl-blue);}
  .slider-group .cap{font-size:8.5px;letter-spacing:.16em;text-align:center;line-height:1.6;font-family:Orbitron,sans-serif;
    font-variant-numeric:tabular-nums;font-feature-settings:"tnum" 1;}
  /* the live value under each slider: reserved width, so dragging from 100 to 5
     doesn't make the caption jump about */
  #pitchVal,#biasVal,#calVal,#outVal,#tapeVal{display:inline-block;min-width:4ch;}
  .slider-group.output{margin-left:auto;}
  .transport{display:flex;gap:8px;margin-top:18px;flex-wrap:wrap;}
  .tbtn{flex:1 1 76px;min-width:64px;height:54px;border-radius:2px;cursor:pointer;
    border:1px solid color-mix(in srgb, var(--fl-blue) 22%, #23211c);
    clip-path:polygon(8px 0,100% 0,100% calc(100% - 8px),calc(100% - 8px) 100%,0 100%,0 8px);
    background:var(--chrome-face);
    box-shadow:0 5px 10px rgba(0,0,0,.65), inset 0 1px 0 rgba(255,255,255,.28),
      inset 0 -2px 3px rgba(0,0,0,.6);
    position:relative;overflow:hidden;
    display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;
    padding:0;text-align:center;line-height:1;
    color:color-mix(in srgb, var(--fl-blue) 80%, #fff);font-size:15px;
    text-shadow:0 0 2px var(--glow-blue),
      0 0 8px color-mix(in srgb, var(--glow-blue) 55%, transparent);
    transition:transform .05s, box-shadow .05s, color .2s, border-color .2s;}
  .tbtn::before{content:"";position:absolute;left:0;right:0;top:0;height:1.5px;
    background:var(--prism);opacity:.6;}
  .tbtn::after{content:"";position:absolute;inset:0;pointer-events:none;
    background:linear-gradient(115deg,transparent 30%,rgba(255,255,255,.10) 42%,transparent 52%);}
  .tbtn small{font-size:8px;letter-spacing:.22em;text-indent:.22em;font-family:Orbitron,sans-serif;
    color:color-mix(in srgb, var(--fl-blue) 82%, #fff);
    text-align:center;line-height:1.2;
    text-shadow:0 0 1px var(--glow-blue),
      0 0 6px color-mix(in srgb, var(--glow-blue) 50%, transparent);}
  .tbtn:hover{border-color:color-mix(in srgb, var(--fl-blue) 75%, #222);
    box-shadow:0 5px 10px rgba(0,0,0,.65), inset 0 1px 0 rgba(255,255,255,.28),
      inset 0 -2px 3px rgba(0,0,0,.6),
      0 0 16px -2px color-mix(in srgb, var(--glow-blue) 55%, transparent);}
  .tbtn:active{transform:translateY(2px);box-shadow:0 1px 3px rgba(0,0,0,.6), inset 0 1px 0 rgba(255,244,214,.08);}
  .tbtn.engaged{
    box-shadow:inset 0 0 20px color-mix(in srgb, var(--glow-blue) 55%, transparent),
      0 1px 2px rgba(0,0,0,.6),
      0 0 22px -2px color-mix(in srgb, var(--glow-blue) 75%, transparent);
    color:color-mix(in srgb, var(--fl-blue) 40%, #fff);
    text-shadow:0 0 2px #fff,
      0 0 6px var(--glow-blue),
      0 0 14px color-mix(in srgb, var(--glow-blue) 65%, transparent);
    transform:translateY(2px);
    border-color:color-mix(in srgb, var(--fl-blue) 90%, #fff);}
  .tbtn.engaged small{color:color-mix(in srgb, var(--fl-blue) 45%, #fff);
    text-shadow:0 0 2px #fff, 0 0 7px var(--glow-blue);}
  /* RECORD: the one red control on an otherwise cool-lit deck */
  .tbtn.rec{color:#8a4a44;}
  .tbtn.rec:hover{border-color:#b8564a;}
  .tbtn.rec small{color:#9a5a52;text-shadow:none;}
  .tbtn.rec.armed{color:#ff5a4e;text-shadow:0 0 8px rgba(255,90,78,.8);
    border-color:#c0453a;animation:recBlink 1s steps(2,start) infinite;}
  .tbtn.rec.armed small{color:#ff8a7e;text-shadow:0 0 5px rgba(255,90,78,.6);}
  .tbtn.rec.rolling{color:#ff5a4e;text-shadow:0 0 10px rgba(255,90,78,.9);
    border-color:#e0503f;box-shadow:inset 0 0 14px rgba(255,60,40,.35), 0 1px 2px rgba(0,0,0,.6);
    transform:translateY(2px);}
  .tbtn.rec.rolling small{color:#ff8a7e;text-shadow:0 0 5px rgba(255,90,78,.6);}
  @keyframes recBlink{50%{opacity:.45}}
  body.recording .digits{color:#ff5a4e;text-shadow:0 0 7px rgba(255,90,78,.8);}
  /* tape type: I / II / IV, sets bias + EQ */
  .tape-select{gap:8px;}
  .tape-types{display:flex;gap:4px;align-items:center;height:21px;padding:0 4px;border-radius:3px;
    background:linear-gradient(180deg,#0b0a08,#191712);border:1px solid #3d382e;
    box-shadow:inset 0 2px 5px rgba(0,0,0,.85);}
  .ttype{min-width:20px;height:15px;padding:0 3px;border-radius:2px;cursor:pointer;
    background:none;border:1px solid transparent;color:var(--scale-dim);opacity:.45;
    font-family:Orbitron,sans-serif;font-size:8px;font-weight:700;letter-spacing:.04em;
    transition:.15s;}
  .ttype:hover{opacity:.8;}
  .ttype.active{opacity:1;color:var(--fl-blue);border-color:color-mix(in srgb, var(--fl-blue) 45%, #222);
    background:rgba(0,0,0,.5);text-shadow:0 0 5px var(--glow-blue);}
  /* TAPE LIBRARY: recorded cassettes, saved locally */
  .rack{margin-top:14px;padding-top:12px;border-top:1px solid var(--gold-line);}
  .rack.hidden{display:none;}
  .rack-head{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:9px;}
  .rack-title{font-family:Orbitron,sans-serif;font-size:8.5px;font-weight:700;letter-spacing:.24em;}
  .rack-count{font-size:8.5px;letter-spacing:.18em;color:color-mix(in srgb, var(--fl-blue) 55%, #7d7a70);
    text-shadow:0 0 6px color-mix(in srgb, var(--glow-blue) 45%, transparent);}
  .rack-shelf{display:flex;gap:8px;flex-wrap:wrap;align-items:stretch;}
  .rack-empty{font-size:9px;letter-spacing:.14em;padding:6px 0;
    color:color-mix(in srgb, var(--fl-blue) 40%, #6f6c64);
    text-shadow:0 0 5px color-mix(in srgb, var(--glow-blue) 30%, transparent);}
  .tape-card{flex:0 1 190px;min-width:150px;position:relative;cursor:pointer;text-align:left;
    border-radius:3px;padding:8px 26px 8px 10px;
    background:linear-gradient(180deg,#141310 0%,#0a0908 55%,#050505 100%);
    border:1px solid #33302a;
    box-shadow:0 3px 7px rgba(0,0,0,.6), inset 0 1px 0 rgba(255,255,255,.10);
    transition:border-color .2s, transform .05s;}
  .tape-card::before{content:"";position:absolute;left:0;right:0;top:0;height:1.5px;
    background:var(--prism);opacity:.45;}
  .tape-card:hover{border-color:color-mix(in srgb, var(--fl-blue) 45%, #222);}
  .tape-card:active{transform:translateY(1px);}
  .tape-card .tc-name{display:block;font-family:"Share Tech Mono",monospace;font-size:11px;
    color:color-mix(in srgb, var(--fl-blue) 80%, #fff);
    text-shadow:0 0 2px var(--glow-blue), 0 0 7px color-mix(in srgb, var(--glow-blue) 50%, transparent);
    white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .tape-card .tc-meta{display:block;margin-top:3px;font-size:8px;letter-spacing:.14em;
    color:var(--champagne-mute);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .tc-eject{position:absolute;top:5px;right:5px;width:16px;height:16px;padding:0;line-height:1;
    background:none;border:1px solid transparent;border-radius:2px;cursor:pointer;
    color:var(--champagne-dim);font-size:11px;transition:.15s;}
  .tc-eject:hover{color:var(--fl-red);border-color:rgba(255,90,78,.5);}
  /* shown only when the deck is opened from file:// — the one thing that stops
     it working, and the one thing a user can't diagnose from the symptoms */
  .disk-warn{position:fixed;left:50%;bottom:22px;transform:translateX(-50%);z-index:9999;
    width:min(560px,92vw);display:flex;flex-direction:column;gap:8px;
    background:linear-gradient(180deg,#2a1410,#160906);
    border:1px solid #b8564a;border-radius:8px;padding:16px 18px;
    box-shadow:0 18px 44px rgba(0,0,0,.8), 0 0 24px -6px rgba(255,90,78,.5);
    font-family:"Share Tech Mono",monospace;color:#f0d8d2;font-size:12.5px;line-height:1.55;}
  .disk-warn strong{font-family:Orbitron,sans-serif;font-size:11px;letter-spacing:.14em;
    color:#ff8a7e;text-shadow:0 0 8px rgba(255,90,78,.6);}
  .disk-warn code{background:rgba(0,0,0,.5);border:1px solid #5c2a24;border-radius:3px;
    padding:1px 5px;color:#ffb0a4;}
  .disk-warn button{align-self:flex-end;margin-top:2px;cursor:pointer;
    background:none;border:1px solid #7a3a32;border-radius:4px;color:#ff9d8c;
    font-family:Orbitron,sans-serif;font-size:9px;letter-spacing:.2em;padding:6px 14px;}
  .disk-warn button:hover{border-color:#ff8a7e;color:#fff;}
  .drawer{margin-top:18px;display:flex;gap:10px;flex-wrap:wrap;}
  /* The loader is a lit element like the meters and the strips: it carries the
     selected display colour, so changing the colour dots relights it too. */
  .drawer input{flex:1 1 260px;background:#06090e;font-family:'Share Tech Mono',monospace;
    border:1px solid color-mix(in srgb, var(--fl-blue) 40%, #15161a);border-radius:4px;
    color:var(--fl-blue);text-shadow:0 0 5px var(--glow-blue);
    padding:11px 13px;font-family:"Courier New",monospace;font-size:13px;outline:none;
    transition:border-color .3s, box-shadow .3s;
    box-shadow:inset 0 2px 7px rgba(0,0,0,.85),
      inset 0 0 14px color-mix(in srgb, var(--glow-blue) 22%, transparent),
      0 0 12px color-mix(in srgb, var(--glow-blue) 38%, transparent);}
  .drawer input::placeholder{color:var(--scale-dim);opacity:.55;text-shadow:none;}
  .drawer input:hover{border-color:color-mix(in srgb, var(--fl-blue) 60%, #15161a);}
  .drawer input:focus{border-color:color-mix(in srgb, var(--fl-blue) 85%, #fff);
    box-shadow:inset 0 2px 7px rgba(0,0,0,.85),
      inset 0 0 18px color-mix(in srgb, var(--glow-blue) 32%, transparent),
      0 0 20px color-mix(in srgb, var(--glow-blue) 62%, transparent);}
  .drawer button{padding:11px 20px;border-radius:2px;border:1px solid color-mix(in srgb, var(--fl-blue) 35%, #222);cursor:pointer;font-size:10px;
    letter-spacing:.26em;text-indent:.26em;text-align:center;background:var(--chrome-face);color:var(--fl-blue);font-weight:700;
    font-family:Orbitron,sans-serif;text-shadow:0 0 5px var(--glow-blue);position:relative;
    transition:border-color .3s, box-shadow .3s;
    box-shadow:inset 0 1px 0 rgba(255,255,255,.28), 0 3px 7px rgba(0,0,0,.55),
      0 0 10px color-mix(in srgb, var(--glow-blue) 30%, transparent);}
  .drawer button::after{content:"";position:absolute;left:0;right:0;top:0;height:1.5px;
    background:var(--prism);opacity:.6;}
  .drawer button:hover{border-color:color-mix(in srgb, var(--fl-blue) 65%, #222);
    box-shadow:inset 0 1px 0 rgba(255,255,255,.28), 0 3px 7px rgba(0,0,0,.55),
      0 0 16px color-mix(in srgb, var(--glow-blue) 55%, transparent);}
  /* the loader goes dark with everything else until the deck is powered */
  body:not(.powered) .drawer input,
  body:not(.powered) .drawer button{box-shadow:inset 0 2px 7px rgba(0,0,0,.85);
    border-color:#23211c;text-shadow:none;}
  /* BLANK is a different kind of action from LOAD: it's an empty shell, so it
     reads as unlit metal rather than a lit signal path. */
  #btnBlank{color:var(--champagne-mute);text-shadow:none;
    border-color:#3a372f;
    box-shadow:inset 0 1px 0 rgba(255,255,255,.20), 0 3px 7px rgba(0,0,0,.55);}
  #btnBlank:hover{color:color-mix(in srgb, var(--fl-blue) 70%, #fff);
    border-color:color-mix(in srgb, var(--fl-blue) 55%, #222);
    text-shadow:0 0 6px color-mix(in srgb, var(--glow-blue) 55%, transparent);
    box-shadow:inset 0 1px 0 rgba(255,255,255,.20), 0 3px 7px rgba(0,0,0,.55),
      0 0 14px color-mix(in srgb, var(--glow-blue) 40%, transparent);}
  .status{margin-top:10px;font-size:10.5px;letter-spacing:.2em;min-height:13px;}
  .drawer-hide{margin-top:8px;background:none;border:none;color:var(--scale-dim);font-size:10px;
    letter-spacing:.24em;cursor:pointer;padding:4px 0;}
  .drawer-hide:hover{color:var(--champagne);}
  .drawer.hidden,.status.hidden{display:none;}
</style>
</head>
