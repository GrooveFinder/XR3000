/* Reel-to-reel tape packs: supply reel shrinks, take-up grows with progress */
/* True C60 geometry at 4 px/mm: 22mm hub (r=44px), full pack 47mm dia (r=94px), 16um tape */
/* HUB_R / PACK_MIN / PACK_MAX are hoisted above the animation loop (see top) */
function setPacks(prog){
  const p=Math.max(0,Math.min(1,prog));
  const left=side==="B"?p:(1-p), right=1-left;
  const rL=PACK_MIN+(PACK_MAX-PACK_MIN)*left;
  const rR=PACK_MIN+(PACK_MAX-PACK_MIN)*right;
  const L=document.getElementById("packL"),R=document.getElementById("packR");
  L.setAttribute("r",(rL+HUB_R)/2);L.setAttribute("stroke-width",Math.max(3,rL-HUB_R));
  R.setAttribute("r",(rR+HUB_R)/2);R.setAttribute("stroke-width",Math.max(3,rR-HUB_R));
  const L2=document.getElementById("packL2"),R2=document.getElementById("packR2");
  if(L2){L2.setAttribute("r",(rL+HUB_R)/2);L2.setAttribute("stroke-width",Math.max(3,rL-HUB_R));}
  if(R2){R2.setAttribute("r",(rR+HUB_R)/2);R2.setAttribute("stroke-width",Math.max(3,rR-HUB_R));}
  /* Threading: outboard tangents off each pack, down to the small corner
     guide rollers, along the bottom over capstans, pressure pad and head. */
  const CL={x:104,y:114}, CR={x:298,y:114};
  const GL={x:40,y:243}, GR={x:362,y:243};
  function tangentPoint(C,r,G,outboardLeft){
    const dx=G.x-C.x, dy=G.y-C.y, dist=Math.hypot(dx,dy);
    const a=Math.acos(Math.min(1,r/dist));
    const base=Math.atan2(dy,dx);
    const t1={x:C.x+r*Math.cos(base+a), y:C.y+r*Math.sin(base+a)};
    const t2={x:C.x+r*Math.cos(base-a), y:C.y+r*Math.sin(base-a)};
    return outboardLeft ? (t1.x<t2.x?t1:t2) : (t1.x>t2.x?t1:t2);
  }
  const RD=70; /* tape leaves the reel flange, not the pack */
  const TL=tangentPoint(CL,RD,{x:GL.x-4,y:GL.y-5},true);
  const TR=tangentPoint(CR,RD,{x:GR.x+4,y:GR.y-5},false);
  const d="M"+TL.x.toFixed(1)+" "+TL.y.toFixed(1)+
    " L"+(GL.x-7)+" "+(GL.y-3)+
    " Q"+(GL.x-8)+" "+(GL.y+7.5)+" "+(GL.x+6)+" "+(GL.y+8)+
    " L150 250 L192 250 L201 253 L210 250 L252 250"+
    " L"+(GR.x-6)+" "+(GR.y+8)+
    " Q"+(GR.x+8)+" "+(GR.y+7.5)+" "+(GR.x+7)+" "+(GR.y-3)+
    " L"+TR.x.toFixed(1)+" "+TR.y.toFixed(1);
  ["tapeShadow","tapePath","tapeSheen"].forEach(id=>{
    const el=document.getElementById(id); if(el) el.setAttribute("d",d);
  });
}
