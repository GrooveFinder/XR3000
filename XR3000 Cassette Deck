<script>
/* ---------- FL bar meters ---------- */
const SEGS=28, HOT_FROM=22, MID_FROM=16;
function buildBar(el){const segs=[];for(let i=0;i<SEGS;i++){const s=document.createElement("div");s.className="seg";el.appendChild(s);segs.push(s);}return{segs,peak:0,peakHold:0};}
const barL=buildBar(document.getElementById("barL"));
const barR=buildBar(document.getElementById("barR"));
let levelL=0,levelR=0,targetL=0,targetR=0,energy=.5;
function paint(bar,lvl){
  const lit=Math.round(lvl*SEGS);
  if(lit>=bar.peak){bar.peak=lit;bar.peakHold=40;}else if(--bar.peakHold<=0&&bar.peak>0)bar.peak--;
  bar.segs.forEach((s,i)=>{s.className="seg"+(i<lit?(" on"+(i>=HOT_FROM?" hot":i>=MID_FROM?" mid":"")):"");
    if(i===bar.peak-1&&bar.peak>lit)s.classList.add("peak");});
}
function animate(){
  if(bootSweep){targetL=targetR=1;levelL+= (1-levelL)*.25;levelR+=(1-levelR)*.22;paint(barL,levelL);paint(barR,levelR);
    requestAnimationFrame(animate);return;}
  const playing=state==="play"||state==="rec",shuttle=state==="ff"||state==="rw";
  if(playing){energy+=(Math.random()-.5)*.3;energy=Math.max(.25,Math.min(1,energy));
    if(Math.random()<.3){targetL=Math.random()*energy;targetR=Math.max(0,Math.min(1,targetL+(Math.random()-.5)*.25));}}
  else if(shuttle){targetL=targetR=.1+Math.random()*.06;}
  else{targetL=targetR=0;}
  levelL+=(targetL-levelL)*(targetL>levelL?.5:.14);
  levelR+=(targetR-levelR)*(targetR>levelR?.5:.14);
  /* REC CAL trims meter calibration, as on a real deck: it moves the needles,
     not the signal. Wind it up and the tape reads hot. */
  const cal=(typeof calTrim==="function")?calTrim():1;
  paint(barL,levelL*cal);paint(barR,levelR*cal);
  tapeFrame();
  requestAnimationFrame(animate);
}

/* ---------- continuous tape motion ----------
   The counter only reports once a second, so instead of snapping the packs to
   each reading we advance them every frame at the rate the transport is really
   running (1x play, ~12x shuttle) and gently correct toward the true position
   whenever a fresh reading lands. The tape visibly creeps spool to spool. */
/* ---------- continuous tape motion ----------
   True C60 geometry at 4 px/mm: 22mm hub, full pack winds inside the reel flange.
   These must be declared before the animation loop, which reads them every frame. */
const HUB_R=23, PACK_MIN=26, PACK_MAX=61;
let tapeProg=0, tapeTarget=0, lastFrame=performance.now();
const SHUTTLE_RATE=12;
function setTapeTarget(p){tapeTarget=Math.max(0,Math.min(1,p));}
function tapeFrame(){
  const now=performance.now(), dt=Math.min(.25,(now-lastFrame)/1000); lastFrame=now;
  /* A blank has no player, so it runs its own clock. Tick it first, then read
     position back through the same path the video path uses. */
  if(blank){
    blankTick();
    const span=blank.len||1800;
    setTapeTarget(blank.pos/span);
    /* the 1s tick is far too coarse for a 12x wind, so the counter is driven
       from the frame loop while a blank is in the deck */
    if(!recRolling){
      const c=$("counter");
      const s=fmt(blank.pos);
      if(c.textContent!==s)c.textContent=s;
    }
  }
  let dur=0, span=240;
  try{
    dur=tapeDuration();
    span=blank?blank.len:(sideSpan()||dur||240);
  }catch(e){ span=dur||240; }        /* first frames can precede full init */
  /* Rate the tape is really travelling, in fractions of a side per second.
     tapeProg always runs 0 -> 1 through whichever side is playing; setPacks()
     maps that onto the correct supply/take-up reel, so the side flip must NOT
     be applied twice here.

     During a WIND the player is genuinely seeking, and shuttleTick() feeds us
     its true position each hop. That reading is authoritative — estimating a
     shuttle speed here as well would fight it and stall the reels. So we chase
     the target hard while winding, and free-run only during PLAY, where the
     counter is coarse (1s) and the frames have to fill the gaps. */
  let rate=0;
  if(state==="play"||state==="rec")rate=1/span;
  const winding=(state==="ff"||state==="rw");
  const running=winding||rate!==0;
  if(blank){
    /* blankTick() already advanced the true position this frame; just follow it,
       or the frame estimate would double-count and run the tape at 2x. */
    tapeProg+=(tapeTarget-tapeProg)*(running?.35:.25);
  }else if(winding){
    tapeProg+=(tapeTarget-tapeProg)*.35;      /* follow the real seek position */
  }else if(rate){
    tapeProg+=rate*dt;
    /* The counter only reports once a second. Between readings the frame rate
       owns the motion; the reading is used to correct accumulated drift, not to
       anchor the tape (which would stall it against a stale value). */
    tapeTarget=Math.max(0,Math.min(1,tapeTarget+rate*dt));
    const drift=tapeTarget-tapeProg;
    if(Math.abs(drift)>.002)tapeProg+=drift*.08;
  }else{
    tapeProg+=(tapeTarget-tapeProg)*.25;      /* parked: settle onto the true spot */
  }
  tapeProg=Math.max(0,Math.min(1,tapeProg));
  setPacks(tapeProg);
  /* Real reels speed up as their pack shrinks: the take-up hub spins fastest
     when it's nearly empty. Feed the current take-up radius back into the rate. */
  if(running){
    const takeUp=(side==="B")?packRadius(1-tapeProg):packRadius(tapeProg);
    const base=(state==="ff"||state==="rw")?.5:2.4;
    const spin=base*(takeUp/PACK_MAX);   /* smaller pack -> shorter period -> faster */
    shell.style.setProperty("--spin",Math.max(.18,spin).toFixed(2)+"s");
  }
}
function packRadius(fill){return PACK_MIN+(PACK_MAX-PACK_MIN)*Math.max(0,Math.min(1,fill));}
/* total seconds of programme on the current side, so wind speed is honest */
function sideSpan(){
  if(!player||!player.getPlaylist)return 0;
  const pl=player.getPlaylist&&player.getPlaylist();
  const d=player.getDuration&&player.getDuration()||0;
  if(!pl||!pl.length)return d;
  if(typeof estWith!=="function")return d;
  const idx=player.getPlaylistIndex(), half=Math.ceil(pl.length/2);
  const inB=idx>=half;
  const ids=inB?pl.slice(half):pl.slice(0,half);
  return estWith(ids).reduce((a,b)=>a+b,0)||d;
}
requestAnimationFrame(animate);

/* ---------- YouTube ---------- */
let player=null,ready=false,state="stop",seekTimer=null,side="A";
let powered=false,bootSweep=false;
const $=id=>document.getElementById(id);
const shell=$("shell");
function setStatus(t){$("status").textContent=t;}
function parseYT(url){
  try{
    const u=new URL(url.trim());
    const list=u.searchParams.get("list");
    let v=u.searchParams.get("v");
    if(!v&&u.hostname.includes("youtu.be"))v=u.pathname.slice(1).split("/")[0];
    if(!v&&u.pathname.startsWith("/shorts/"))v=u.pathname.split("/")[2];
    if(!v&&u.pathname.startsWith("/embed/"))v=u.pathname.split("/")[2];
    return{v,list};
  }catch(e){
    if(/^[\w-]{11}$/.test(url.trim()))return{v:url.trim(),list:null};
    return{v:null,list:null};
  }
}
if(location.protocol==="file:"){
  /* Opened by double-clicking the file. YouTube refuses to embed from file://
     (error 153) and the browser blocks localStorage, so the deck cannot play
     or save. This needs saying loudly, not hidden in the status line. */
  setStatus("\u26A0 OPENED FROM DISK \u00B7 YOUTUBE AND SAVING ARE BLOCKED");
  window.addEventListener("DOMContentLoaded",()=>{
    const w=document.createElement("div");
    w.className="disk-warn";
    w.innerHTML='<strong>&#9888; This deck is opened from your hard drive</strong>'+
      '<span>YouTube blocks playback from <code>file://</code> (error 153), and the browser '+
      "won't let the Tape Library save. Nothing here will work properly this way.</span>"+
      '<span>Put it online (GitHub Pages, Netlify) or serve it locally, then open it '+
      'over <code>http://</code> and everything works.</span>'+
      '<button type="button">Dismiss</button>';
    w.querySelector("button").onclick=()=>w.remove();
    document.body.appendChild(w);
  });
}
const tag=document.createElement("script");
tag.src="https://www.youtube.com/iframe_api";
document.head.appendChild(tag);
window.onYouTubeIframeAPIReady=function(){
  player=new YT.Player("ytplayer",{
    playerVars:{playsinline:1,controls:0,rel:0},
    events:{
      onReady:()=>{ready=true;player.unMute();player.setVolume(parseInt($("outLevel").value,10));setStatus("STANDBY · INSERT CASSETTE");},
      onStateChange:(e)=>{
        if(e.data===YT.PlayerState.PLAYING&&state!=="ff"&&state!=="rw")setMode("play");
        else if(e.data===YT.PlayerState.PAUSED&&state==="play")setMode("pause");
        else if(e.data===YT.PlayerState.ENDED){
          /* AUTO REVERSE: at the end of the tape the deck turns it over and
             keeps running, rather than simply stopping. */
          const pl=player.getPlaylist&&player.getPlaylist();
          const lastTrack=!pl||!pl.length||player.getPlaylistIndex()>=pl.length-1;
          if(swOn("rev")&&lastTrack&&side==="A"){
            flipTape("B");
            tapeProg=0;setTapeTarget(0);   /* side B starts at its own beginning */
            setTimeout(()=>{
              player.seekTo(0);player.playVideo();
              if(pl&&pl.length)player.playVideoAt(0);
              setMode(recRolling?"rec":"play","AUTO REVERSE \u25C0\u25B6 \u00B7 SIDE B");
            },460);
          }else{
            if(recRolling)stopRecord();
