    setTimeout(()=>{bootSweep=false;},700);
    naacFlash();
    setTimeout(()=>{document.body.classList.remove("boot");setStatus("STANDBY \u00B7 INSERT CASSETTE");},1600);
  }else{
    powered=false;
    if(recRolling)stopRecord();   /* power down shelves the tape rather than losing it */
    document.body.classList.remove("powered","boot");
    cancelWind();stopScan();
    if(ready){player.pauseVideo();}
    setMode("stop","");setStatus("POWER OFF");
  }
};
function needPower(){if(!powered){setStatus("PRESS POWER \u00B7 DECK IS OFF");return true;}return false;}

/* full screen: hides the browser's toolbars top and bottom; Esc exits too */
$("btnFS").onclick=()=>{
  if(!document.fullscreenElement){
    document.documentElement.requestFullscreen().catch(()=>setStatus("FULL SCREEN NOT PERMITTED HERE"));
  }else{
    document.exitFullscreen();
  }
};
document.addEventListener("fullscreenchange",()=>{
  $("btnFS").innerHTML=document.fullscreenElement?"\u26F6 EXIT FULL SCREEN":"\u26F6 FULL SCREEN";
});

/* COUNTER MEMORY: press to store the current counter point (button stays lit);
   REW then winds back and stops exactly there, like memory-stop on the era's decks */
let memoryPoint=null;
$("btnMemo").onclick=()=>{
  if(!ready)return;
  if(memoryPoint===null){
    memoryPoint=player.getCurrentTime()||0;
    $("btnMemo").classList.add("engaged");
    setStatus("MEMORY SET \u00B7 "+fmt(memoryPoint));
  }else{
    memoryPoint=null;
    $("btnMemo").classList.remove("engaged");
    setStatus("MEMORY CLEARED");
  }
};

/* INTRO SCAN: samples the first seconds of each following track, like Music Scan */
let scanTimer=null;
function stopScan(msg){
  if(scanTimer){clearInterval(scanTimer);scanTimer=null;}
  $("btnScan").classList.remove("engaged");
  if(msg)setStatus(msg);
}
$("btnScan").onclick=()=>{
  if(!ready)return;
  if(scanTimer){stopScan("INTRO SCAN CANCELLED \u00B7 RESUMING");setMode("play");return;}
  const pl=player.getPlaylist&&player.getPlaylist();
  if(!pl||pl.length<2){setStatus("INTRO SCAN NEEDS A PLAYLIST");return;}
  $("btnScan").classList.add("engaged");
  player.playVideo();setMode("play","INTRO SCAN \u00B7 SAMPLING EACH PROGRAM");
  $("btnScan").classList.add("engaged");
  let elapsed=0;
  scanTimer=setInterval(()=>{
    elapsed+=1;
    if(elapsed>=8){
      elapsed=0;
      const idx=player.getPlaylistIndex();
      if(idx>=pl.length-1){stopScan("INTRO SCAN COMPLETE");return;}
      player.nextVideo();
      setStatus("INTRO SCAN \u00B7 PROGRAM "+(idx+2)+" / "+pl.length);
    }
  },1000);
};

/* BIAS FINE now reads against the loaded formulation, and drives the hiss
   character through updateTapeAudio(). REC CAL trims the meter calibration,
   exactly as it would on a real deck: it moves the needles, not the signal. */
$("biasFine").oninput=e=>{
  const v=parseInt(e.target.value,10);
  const err=v-TAPES[tapeType].bias;
  $("biasVal").textContent=(v>0?"+":"")+v+(err===0?" \u2713":"");
  updateTapeAudio();savePrefs();
};
$("recCal").oninput=e=>{$("calVal").textContent=(e.target.value>0?"+":"")+e.target.value;savePrefs();};
function calTrim(){return 1+((parseInt($("recCal").value,10)||0)*.08);}

/* ======================= RECORD =======================
   A browser cannot capture YouTube's audio (it lives in a cross-origin iframe
   with no route to the Web Audio graph), so the deck cannot cut a WAV of the
   song. What it CAN do is what a real deck's counter and index marks did:
   log what passed the heads. Arm RECORD, and every programme that plays is
   written to the cassette with its position and length. The result is a
   playable tape you can name, shelve, and load again. */
let recArmed=false, recRolling=false, recStart=0, recPaused=0, recTape=null, lastCapId=null;
function recElapsed(){return recRolling?((Date.now()-recStart)/1000)-recPaused:0;}
function captureTick(){
  if(!recTape)return;
  /* Recording a blank with no source rolls the tape but writes nothing to it —
     there's no signal at the input. The counter still runs, as it must. */
  if(blank)return;
  if(!player||!player.getVideoData)return;
  const d=player.getVideoData()||{};
  if(!d.video_id)return;
  if(d.video_id===lastCapId){
    const last=recTape.tracks[recTape.tracks.length-1];
    if(last)last.len=Math.max(last.len,Math.round(player.getCurrentTime()||0));
    return;
  }
  lastCapId=d.video_id;
  const {artist,song}=splitTitle(d.title||"UNKNOWN",d.author);
  recTape.tracks.push({
    id:d.video_id, song, artist,
    at:Math.round(recElapsed()),        /* index mark: where on the tape it starts */
    len:Math.round(player.getCurrentTime()||0)
  });
  setStatus("\u25CF REC \u00B7 PROGRAM "+recTape.tracks.length+" \u00B7 "+song.toUpperCase());
  naacFlash();
}
$("btnRec").onclick=()=>{
  if(needPower())return;
  if(!blank&&!ready)return;            /* a blank has no player, but is recordable */
  if(needTape())return;                /* nothing to record onto */
  if(recRolling){stopRecord();return;}
  if(recArmed){                       /* second press while armed: disarm */
    recArmed=false;$("btnRec").classList.remove("armed");
    setStatus("RECORD DISARMED");return;
  }
  recArmed=true;$("btnRec").classList.add("armed");
  setStatus("\u25CF RECORD ARMED \u00B7 PRESS PLAY TO ROLL TAPE");
};
function startRecord(){
  if(!recArmed)return;
  recArmed=false;recRolling=true;recPaused=0;lastCapId=null;
  recStart=Date.now();
  /* a blank has no player behind it, so there's no playlist and no seed video */
  const pl=(!blank&&player&&player.getPlaylist)?player.getPlaylist():null;
  recTape={
    id:"t"+Date.now(),
    name:"",
    tape:tapeType,
    blank:blankLoaded(),
    dolby:swOn("dolbyC")?"C":swOn("dolbyB")?"B":"OFF",
    list:(pl&&pl.length)?pl.slice():null,
    seed:(!blank&&player&&player.getVideoData)?((player.getVideoData()||{}).video_id||null):null,
    tracks:[], len:0, made:Date.now()
  };
  $("btnRec").classList.remove("armed");$("btnRec").classList.add("rolling");
  document.body.classList.add("recording");
  clunk(true);
  setStatus("\u25CF RECORDING \u00B7 "+TAPES[tapeType].name+" \u00B7 DOLBY "+recTape.dolby);
  captureTick();updateTapeAudio();
}
function stopRecord(){
  if(!recRolling)return;
  recRolling=false;
  $("btnRec").classList.remove("rolling","armed");
  document.body.classList.remove("recording");
  clunk(true);updateTapeAudio();
  recTape.len=Math.round(recElapsed());
  if(!recTape.tracks.length){
    setStatus(recTape.blank
      ? "\u25A0 BLANK RECORDED \u00B7 NO SOURCE AT INPUT \u00B7 TAPE IS STILL EMPTY"
      : "RECORDING DISCARDED \u00B7 NOTHING PASSED THE HEADS");
    recTape=null;return;
  }
  const first=recTape.tracks[0];
  const suggested=(recTape.tracks.length>1?"MIXTAPE \u00B7 "+first.artist:first.artist+" \u00B7 "+first.song).slice(0,42);
  const nm=prompt("Label this cassette:",suggested.toUpperCase());
  if(nm===null){setStatus("RECORDING DISCARDED");recTape=null;return;}
  recTape.name=(nm.trim()||suggested).toUpperCase().slice(0,42);
  library.unshift(recTape);
  saveLibrary();renderRack();
  setStatus("\u25A0 TAPE SAVED \u00B7 "+recTape.name+" \u00B7 "+recTape.tracks.length+" PROGRAMS \u00B7 "+fmt(recTape.len));
  recTape=null;
}

/* ======================= BLANK TAPE =======================
   A real deck ships with blank cassettes: you can load one, wind it end to end,
   flip it and record onto it — it simply makes no sound, because nothing is on
   it yet. There's no YouTube player behind a blank, so the tape needs its own
   clock. Everything downstream (packs, counter, reels) reads position through
   tapeTime()/tapeDuration(), so it works identically for tape and for video. */
const BLANK_LEN={ "C46":46*60, "C60":60*60, "C90":90*60 };
let blank=null;          /* {len, pos, len} when a blank is loaded, else null */
let blankLast=0;
function blankLoaded(){return blank!==null;}
/* the blank's own transport: advances its clock at the transport's real rate */
/* A real deck winds a full C60 side (30 min of tape) in roughly a minute — call
   it ~30x real time. The 12x used for video is deliberately gentler, because
   there we're seeking a stream and want to hear where we land; a blank has
   nothing to hear, so it winds at true mechanism speed and you watch it move. */
const BLANK_SHUTTLE=30;
function blankTick(){
  if(!blank)return;
  const now=performance.now();
  const dt=Math.min(.5,(now-blankLast)/1000);
  blankLast=now;
  let v=0;
  if(state==="play"||state==="rec")v=1;
  else if(state==="ff")v=BLANK_SHUTTLE;
  else if(state==="rw")v=-BLANK_SHUTTLE;
  if(!v)return;
  blank.pos+=v*dt;
  /* wound to either end: the transport stops, as it must */
  if(blank.pos>=blank.len){
    blank.pos=blank.len;
    if(swOn("rev")&&side==="A"){autoReverseBlank();return;}
    setMode("stop","END OF TAPE \u00B7 SIDE "+side);
  }else if(blank.pos<=0){
    blank.pos=0;
    if(state==="rw")setMode("stop","TAPE REWOUND \u00B7 SIDE "+side);
  }
}
function autoReverseBlank(){
  flipTape("B");
  blank.pos=0;tapeProg=0;setTapeTarget(0);
  setTimeout(()=>setMode("play","AUTO REVERSE \u25C0\u25B6 \u00B7 SIDE B"),460);
}
/* Unified position readers: the rest of the deck asks these, not the player. */
function tapeTime(){
  if(blank)return blank.pos;
  return (player&&player.getCurrentTime&&player.getCurrentTime())||0;
}
function tapeDuration(){
  if(blank)return blank.len;
  return (player&&player.getDuration&&player.getDuration())||0;
}
function loadBlank(len){
  if(needPower())return;
  const secs=BLANK_LEN[len]||BLANK_LEN.C60;
  /* a blank has two sides, so each side is half the shell's stated length */
  blank={len:secs/2, pos:0, label:len};
  blankLast=performance.now();
  if(ready&&player.stopVideo){player.stopVideo();}
  side="A";$("sideMark").textContent="A";shell.classList.remove("sideB");
  tapeProg=0;setTapeTarget(0);setPacks(0);
  memoryPoint=null;$("btnMemo").classList.remove("engaged");stopScan();
  doorOpen(true);setTimeout(()=>doorOpen(false),650);
  $("labelSong").textContent="";
  $("infoSong").textContent="BLANK TAPE";
  $("infoArtist").textContent="\u2014";
  $("infoAlbum").textContent=len+" \u00B7 "+TAPES[tapeType].name+" \u00B7 SIDE A";
  $("infoTrack").textContent="\u2014 / \u2014";
  $("counter").textContent="000:00";
  $("duration").textContent="/ "+fmt(secs/2);   /* per-side length, shown at once */
  const mm=document.querySelector(".metal-mark");
  if(mm)mm.textContent="TYPE "+tapeType+" \u00B7 "+TAPES[tapeType].eq+" EQ";
  const band=document.querySelector(".band .max-badge");
  setMode("stop","BLANK "+len+" LOADED \u00B7 "+TAPES[tapeType].name+" \u00B7 NOTHING RECORDED");
  updateTapeAudio();
}
function ejectBlank(){
  blank=null;
  $("infoSong").textContent="\u2014";
  $("infoAlbum").textContent="\u2014";
}
$("btnBlank").onclick=()=>loadBlank("C60");

/* ---------- TAPE LIBRARY (persists in this browser) ---------- */
let library=[];
try{library=JSON.parse(localStorage.getItem("xr3000-library")||"[]");}catch(e){library=[];}
function saveLibrary(){try{localStorage.setItem("xr3000-library",JSON.stringify(library));}catch(e){}}
function renderRack(){
  const shelf=$("rackShelf");
  $("rackCount").textContent=library.length+" CASSETTE"+(library.length===1?"":"S");
  if(!library.length){
    shelf.innerHTML='<span class="rack-empty">NO RECORDINGS YET \u00B7 PRESS RECORD WHILE A TAPE PLAYS</span>';
    return;
  }
  shelf.innerHTML="";
  library.forEach(t=>{
    const card=document.createElement("button");
    card.className="tape-card";
    card.title="Load this cassette";
    card.innerHTML='<span class="tc-name"></span><span class="tc-meta"></span>';
    card.querySelector(".tc-name").textContent=t.name;
    card.querySelector(".tc-meta").textContent=
      t.tracks.length+" PROG \u00B7 "+fmt(t.len)+" \u00B7 TYPE "+t.tape+" \u00B7 DOLBY "+t.dolby;
    card.onclick=()=>loadFromLibrary(t.id);
    const del=document.createElement("button");
    del.className="tc-eject";del.innerHTML="&times;";del.title="Erase this cassette";
    del.onclick=e=>{
      e.stopPropagation();
      library=library.filter(x=>x.id!==t.id);
      saveLibrary();renderRack();setStatus("TAPE ERASED \u00B7 "+t.name);
    };
    card.appendChild(del);
    shelf.appendChild(card);
  });
}
function loadFromLibrary(id){
  const t=library.find(x=>x.id===id);
  if(!t)return;
  if(needPower()||!ready)return;
  ejectBlank();
  setTapeType(t.tape);
  document.querySelectorAll('[data-sw="dolbyB"],[data-sw="dolbyC"]').forEach(x=>x.classList.remove("on"));
  if(t.dolby==="B")document.querySelector('[data-sw="dolbyB"]').classList.add("on");
  if(t.dolby==="C")document.querySelector('[data-sw="dolbyC"]').classList.add("on");
  side="A";$("sideMark").textContent="A";shell.classList.remove("sideB");
  tapeProg=0;setTapeTarget(0);
  doorOpen(true);setTimeout(()=>doorOpen(false),650);
  if(t.list&&t.list.length)player.loadPlaylist({playlist:t.list});
  else if(t.tracks.length)player.loadPlaylist({playlist:t.tracks.map(x=>x.id)});
  else if(t.seed)player.loadVideoById(t.seed);
  else return;
  setMode("play","PLAYING \u00B7 "+t.name);
  updateTapeAudio();
}
renderRack();

/* ---------- PREFERENCES (last link, colour, switches, tape) ---------- */
function savePrefs(){
  try{
    localStorage.setItem("xr3000-prefs",JSON.stringify({
      url:$("urlIn").value,
      colour:(document.querySelector(".dot.active")||{}).dataset?.c||"blue",
      tape:tapeType,
      bias:$("biasFine").value, cal:$("recCal").value,
      out:$("outLevel").value, pitch:$("pitch").value,
      sw:["dolbyB","dolbyC","mpx","naacSw","rev","direct","preset"]
         .filter(n=>swOn(n))
    }));
  }catch(e){}
}
function loadPrefs(){
  let p=null;
  try{p=JSON.parse(localStorage.getItem("xr3000-prefs")||"null");}catch(e){}
  if(!p)return;
  if(p.url)$("urlIn").value=p.url;
  if(p.colour&&p.colour!=="blue"){
    document.querySelectorAll(".dot").forEach(x=>x.classList.toggle("active",x.dataset.c===p.colour));
    document.body.setAttribute("data-disp",p.colour);
  }
  if(Array.isArray(p.sw)){
    ["dolbyB","dolbyC","mpx","naacSw","rev","direct","preset"].forEach(n=>{
      const t=document.querySelector('[data-sw="'+n+'"]');
      if(!t)return;
      /* the .toggle.on + .lamp rule lights the lamp; writing inline styles here
         would override it with a dimmer glow, so just set the class. */
      t.classList.toggle("on",p.sw.includes(n));
    });
  }
  if(p.bias!==undefined){$("biasFine").value=p.bias;$("biasFine").dispatchEvent(new Event("input"));}
  if(p.cal!==undefined){$("recCal").value=p.cal;$("recCal").dispatchEvent(new Event("input"));}
  if(p.out!==undefined){$("outLevel").value=p.out;$("outVal").textContent=p.out;}
  if(p.pitch!==undefined){$("pitch").value=p.pitch;$("pitch").dispatchEvent(new Event("input"));}
  if(p.tape)setTapeType(p.tape); else setTapeType("IV");
}
loadPrefs();
$("urlIn").addEventListener("change",savePrefs);

/* ---------- KEYBOARD TRANSPORT ---------- */
document.addEventListener("keydown",e=>{
  if(/^(INPUT|TEXTAREA)$/.test(e.target.tagName))return;
  if(e.metaKey||e.ctrlKey||e.altKey)return;
  const k=e.key.toLowerCase();
  const hit=id=>{e.preventDefault();$(id).click();};
  if(e.code==="Space")return hit(state==="play"?"btnPause":"btnPlay");
  if(k==="arrowright")return hit(e.shiftKey?"btnNext":"btnFF");
  if(k==="arrowleft") return hit(e.shiftKey?"btnPrev":"btnRew");
  if(k==="s")return hit("btnStop");
  if(k==="r")return hit("btnRec");
  if(k==="e")return hit("btnEject");
  if(k==="m")return hit("btnMemo");
  if(k==="p")return hit("btnPwr");
  if(k==="arrowup"||k==="arrowdown"){
    e.preventDefault();
    const o=$("outLevel");
    o.value=Math.max(0,Math.min(100,(parseInt(o.value,10)||0)+(k==="arrowup"?5:-5)));
    o.dispatchEvent(new Event("input",{bubbles:true}));
  }
});

/* double-click any slider returns it to its centre detent, like tapping
   a real pot back to its indent (pitch 0%, bias 0, cal 0, output 100) */
const DETENTS={pitch:"100",biasFine:"0",recCal:"0",outLevel:"100"};
Object.keys(DETENTS).forEach(id=>{
  const el=$(id); if(!el)return;
  el.addEventListener("dblclick",()=>{
    el.value=DETENTS[id];
    el.dispatchEvent(new Event("input",{bubbles:true}));
  });
});

/* display colour selector */
document.querySelectorAll(".dot").forEach(d=>{
  d.onclick=()=>{
    document.querySelectorAll(".dot").forEach(x=>x.classList.remove("active"));
    d.classList.add("active");
    const c=d.dataset.c;
    if(c==="blue")document.body.removeAttribute("data-disp");
    else document.body.setAttribute("data-disp",c);
    savePrefs();
  };
});

/* cassette door */
function doorOpen(o){$("bay").classList.toggle("open",o);}
$("btnDrawer").onclick=()=>{
  const hidden=$("drawer").classList.toggle("hidden");
  $("status").classList.toggle("hidden",hidden);
  $("btnDrawer").innerHTML=hidden?"&#9660; SHOW LOADER":"&#9650; HIDE LOADER";
};
/* YouTube only honours a fixed set of playback rates. A continuous slider
   would show a number the deck can't actually hit, so snap to what's real. */
$("pitch").oninput=e=>{
  const want=e.target.value/100;
  let rates=[0.5,0.75,1,1.25,1.5];
  if(ready&&player.getAvailablePlaybackRates){
    const r=player.getAvailablePlaybackRates();
    if(r&&r.length)rates=r;
  }
  const p=rates.reduce((a,b)=>Math.abs(b-want)<Math.abs(a-want)?b:a,rates[0]);
  $("pitchVal").textContent=(p>=1?"+":"")+Math.round((p-1)*100)+"%";
  if(ready&&player.setPlaybackRate)player.setPlaybackRate(p);
  savePrefs();
};
$("outLevel").oninput=e=>{const v=parseInt(e.target.value,10);
  $("outVal").textContent=v;
  if(ready){player.unMute();player.setVolume(v);}
  if(masterTape)masterTape.gain.setTargetAtTime(v/100,AC.currentTime,.05);
  savePrefs();};
$("monToggle").onclick=()=>{
  const m=$("monitor");m.classList.toggle("min");
  $("monToggle").innerHTML=m.classList.contains("min")?"VIDEO \u25BE":"VIDEO \u25B4";
};
document.querySelectorAll(".toggle").forEach(t=>{
  t.onclick=()=>{
    t.classList.toggle("on");
    const sw=t.dataset.sw;
    if(t.classList.contains("on")&&(sw==="dolbyB"||sw==="dolbyC")){
      const o=document.querySelector(`[data-sw="${sw==="dolbyB"?"dolbyC":"dolbyB"}"]`);
      o.classList.remove("on");
    }
    if(typeof updateTapeAudio==="function")updateTapeAudio();
    if(typeof savePrefs==="function")savePrefs();
  };
});
</script>
